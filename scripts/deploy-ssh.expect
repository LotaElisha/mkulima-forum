#!/usr/bin/env expect
# deploy-ssh.expect — password-based SSH helper for CI/deploy scripts
# Usage: ./deploy-ssh.expect "remote command"

set timeout 60
set password $env(DEPLOY_SSH_PASSWORD)
set host "72.60.93.176"
set user "u241489594"
set port "65002"
set cmd [lindex $argv 0]

spawn ssh -p $port $user@$host $cmd
expect {
    "yes/no" { send "yes\r"; exp_continue }
    -re {\(?\S+@\S+\)?'s password:} { send "$password\r" }
    timeout  { puts "Timeout!"; exit 1 }
}
expect eof
